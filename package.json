{
  "name": "onlinesched",
  "version": "1.2.0",
  "description": "A flexible event scheduling plugin for WordPress",
  "main": "index.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/onlinesched/OnlineSched.git"
  },
  "author": "BL, BM, AL & Contributors",
  "license": "GPL-2.0-or-later",
  "bugs": {
    "url": "https://github.com/onlinesched/OnlineSched/issues"
  },
  "homepage": "https://github.com/onlinesched/OnlineSched#readme",
  "devDependencies": {
    "@babel/core": "^7.23.3",
    "@babel/preset-env": "^7.23.3",
    "@babel/preset-react": "^7.28.5",
    "@playwright/test": "^1.59.1",
    "autoprefixer": "^10.4.16",
    "babel-loader": "^9.1.3",
    "css-loader": "^6.8.1",
    "css-minimizer-webpack-plugin": "^8.0.0",
    "mini-css-extract-plugin": "^2.7.6",
    "postcss-loader": "^7.3.3",
    "sass": "^1.97.3",
    "sass-loader": "^13.3.2",
    "style-loader": "^3.3.3",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^5.2.3"
  },
  "scripts": {
    "build": "webpack --mode=production",
    "release": "npm run build && node scripts/package-release.js",
    "dev": "webpack --mode=development",
    "watch": "webpack --mode=development --watch",
    "test": "npx playwright test --config=tests/playwright.config.js",
    "test:headed": "npx playwright test --config=tests/playwright.config.js --headed",
    "test:ui": "npx playwright test --config=tests/playwright.config.js --ui",
    "test:kiosk": "npx playwright test --config=tests/playwright.config.js --project=kiosk",
    "test:kiosk:chromium": "PLAYWRIGHT_NO_EDGE=1 npx playwright test --config=tests/playwright.config.js --project=kiosk",
    "test:mobile": "npx playwright test --config=tests/playwright.config.js --project=mobile-iphone --project=mobile-android",
    "test:firefox": "npx playwright test --config=tests/playwright.config.js --project=firefox",
    "test:webkit": "npx playwright test --config=tests/playwright.config.js --project=webkit",
    "test:seed": "bash tests/fixtures/seed-test-events.sh",
    "test:setup": "npm run test:seed && npx playwright install chromium msedge firefox webkit"
  },
  "engines": {
    "node": ">=22"
  },
  "keywords": [],
  "dependencies": {
    "@fontsource/metropolis": "^5.2.5",
    "@fortawesome/fontawesome-free": "^6.4.2"
  }
}
